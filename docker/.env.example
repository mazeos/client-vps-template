# ── Dominio principal ────────────────────────────────────────────
DOMAIN=tudominio.com
ACME_EMAIL=tu@email.com

# ── Traefik ──────────────────────────────────────────────────────
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=cambia_esto

# ── n8n ──────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=genera_una_clave_aleatoria_32chars
N8N_USER=admin
N8N_PASSWORD=cambia_esto

# ── Supabase ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=cambia_esto
POSTGRES_DB=supabase
JWT_SECRET=genera_un_jwt_secret_minimo_32chars
ANON_KEY=tu_anon_key
SERVICE_ROLE_KEY=tu_service_role_key

# ── Portainer ────────────────────────────────────────────────────
# (sin variables extra — usa UI en primer arranque)

# ── FlareSolverr ─────────────────────────────────────────────────
FLARESOLVERR_LOG_LEVEL=info

# ── Playwright ───────────────────────────────────────────────────
PLAYWRIGHT_TOKEN=cambia_esto
